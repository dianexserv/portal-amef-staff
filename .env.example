# =================================================================
# Portal AMEF Staff — exemplu de configurație
# Copiati acest fisier in `.env` si completati valorile reale.
# NU comiteti `.env` in repo (este in .gitignore).
# =================================================================

# -- Server ------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
# Origin permis pentru CORS — frontend-ul Vite implicit pe :5173.
# In staging/production: domeniul real (ex: https://amef.dianex.ro).
CORS_ORIGIN=http://localhost:5173

# -- Auth (Firebase + JWT propriu) -------------------------------
FIREBASE_PROJECT_ID=portal-amef-staging
JWT_SECRET_NAME=jwt-secret-staging
JWT_EXPIRY_HOURS=1
REFRESH_TOKEN_EXPIRY_DAYS=7

# -- Database (Cloud SQL via Secret Manager) ---------------------
# Numele secretelor sunt derivate prin conventie din NODE_ENV — NU le seta aici.
#   production  → shared-db-connection / tenant-{slug}-db-connection
#   staging/dev → shared-staging-db-connection / tenant-{slug}-staging-db-connection
# (single source of truth: server/src/utils/secret-naming.js)
GCP_PROJECT_ID=robot-gmail-302413

# -- Test database (local integration tests) ---------------------
# Setati doar daca vreti sa rulati `pnpm test:integration` local.
# Necesita PostgreSQL rulat local (Docker sau Cloud SQL Auth Proxy).
# Exemplu: postgresql://test:test@localhost:5432/test_amef
TEST_DB_CONNECTION_STRING=

# -- Servicii externe --------------------------------------------
ANAF_API_BASE_URL=https://webservicesp.anaf.ro
ERP_SYNC_SERVICE_URL=https://portal-amef-erp-sync-xxxx-ew.a.run.app
ANAF_SIGNER_DEFAULT_TIMEOUT_MS=30000

# -- Storage (GCS) -----------------------------------------------
GCS_BUCKET_PREFIX=portal-amef-docs

# -- Email (SendGrid) --------------------------------------------
SENDGRID_API_KEY_SECRET_NAME=sendgrid-api-key-staging
EMAIL_FROM_ADDRESS=portal@dianex.ro

# -- Frontend (Vite, expuse la browser cu prefix VITE_) ----------
VITE_API_BASE_URL=http://localhost:3001
VITE_FIREBASE_API_KEY=replace_with_real_value
VITE_FIREBASE_AUTH_DOMAIN=portal-amef-staging.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=portal-amef-staging
